@page "/contact"

<PageTitle>Contact - Michael Gustavus</PageTitle>

<SectionHeading Title="Contact" Subtitle="@($"The best ways to reach {ResumeData.Contact.Name}")" />

<div class="contact-grid">
    <a class="contact-card" href="mailto:@ResumeData.Contact.Email">
        <span class="contact-label">Email</span>
        <span class="contact-value">@ResumeData.Contact.Email</span>
    </a>
    <a class="contact-card" href="tel:@ResumeData.Contact.Phone">
        <span class="contact-label">Phone</span>
        <span class="contact-value">@ResumeData.Contact.Phone</span>
    </a>
    <div class="contact-card">
        <span class="contact-label">Location</span>
        <span class="contact-value">@ResumeData.Contact.Location</span>
    </div>
    <a class="contact-card" href="@ResumeData.Contact.LinkedInUrl" target="_blank" rel="noopener noreferrer">
        <span class="contact-label">LinkedIn</span>
        <span class="contact-value">Connect on LinkedIn</span>
    </a>
    <a class="contact-card" href="@ResumeData.Contact.GitHubUrl" target="_blank" rel="noopener noreferrer">
        <span class="contact-label">GitHub</span>
        <span class="contact-value">Browse repositories</span>
    </a>
</div>
